---
import ExamAnswersToggle from "/src/components/ExamAnswersToggle.astro";

const {pageTitle,examControls=false}=Astro.props;
---

<nav class="border-b border-slate-200/80 bg-white/85 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80 sticky top-0 z-40">
	<div class="mx-auto flex w-full max-w-6xl items-center gap-4 px-4 py-4 sm:px-6 lg:px-8">
		<a class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white shadow-sm no-underline transition hover:-translate-y-0.5 hover:border-slate-300 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700" href="/" title="回到首页">
			<img alt="BYR Docs" class="h-7 w-7" src="/favicon.svg" />
		</a>
		<span class="min-w-0 flex-1 truncate text-lg font-semibold tracking-tight text-slate-950 sm:text-2xl dark:text-white">{pageTitle}</span>
		{examControls&&<ExamAnswersToggle />}
	</div>
</nav>
