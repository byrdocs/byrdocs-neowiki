---
const { editHref, showTocToggle = false } = Astro.props;
---

<div
  class="floating-toolbar"
  id="examToolbar"
  data-expanded="false"
>
  <div
    class="floating-toolbar-actions"
    id="examToolbarActions"
  >
    <button
      class="floating-toolbar-control cursor-pointer transition-opacity active:scale-95"
      id="backToTop"
      type="button"
      aria-label="回到顶部"
      data-tooltip="回到顶部"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
        <path d="M18 15l-6-6-6 6"></path>
      </svg>
    </button>
    {
      showTocToggle && (
        <button
          class="floating-toolbar-control exam-toolbar-toc-toggle cursor-pointer active:scale-95"
          id="examTocMobileToggle"
          type="button"
          aria-label="显示目录"
          aria-expanded="false"
          data-tooltip="目录"
          data-toolbar-action
        >
          <svg
            aria-hidden="true"
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          >
            <path d="M9 6h10"></path>
            <path d="M9 12h10"></path>
            <path d="M9 18h10"></path>
            <circle cx="5" cy="6" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="5" cy="12" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="5" cy="18" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </button>
      )
    }
    {
      editHref && (
        <a
          class="no-underline floating-toolbar-control active:scale-95"
          href={editHref}
          aria-label="在 GitHub 上编辑"
          data-tooltip="在 GitHub 上编辑"
          data-toolbar-action
        >
          <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M12 20h9"></path>
            <path d="m16.5 3.5 4 4L8 20l-5 1 1-5 12.5-12.5Z"></path>
          </svg>
        </a>
      )
    }
    <button
      class="floating-toolbar-control cursor-pointer active:scale-95"
      id="examPrint"
      type="button"
      aria-label="打印试卷"
      data-tooltip="打印试卷"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <polyline points="6 9 6 2 18 2 18 9"></polyline>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
        <rect x="6" y="14" width="12" height="8"></rect>
      </svg>
    </button>
    <button
      class="floating-toolbar-control cursor-pointer active:scale-95 disabled:cursor-default disabled:opacity-50"
      id="examAnswersToggle"
      type="button"
      aria-label="显示全部答案"
      aria-pressed="false"
      data-tooltip="显示全部答案"
      data-toolbar-action
    >
      <svg aria-hidden="true" class="h-5 w-5" data-exam-toggle-icon="show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6Z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <svg aria-hidden="true" class="h-5 w-5" data-exam-toggle-icon="hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8">
        <path d="M3 3l18 18"></path>
        <path d="M10.6 10.7a2 2 0 0 0 2.7 2.7"></path>
        <path d="M9.4 5.6A10.7 10.7 0 0 1 12 5.2c6.4 0 10 6 10 6a17.7 17.7 0 0 1-4.1 4.6"></path>
        <path d="M6.2 6.3C3.7 8 2 10.8 2 10.8s3.6 6 10 6c1.2 0 2.4-.2 3.4-.6"></path>
      </svg>
    </button>
  </div>
  <button
    class="floating-toolbar-control floating-toolbar-toggle cursor-pointer active:scale-95"
    id="examToolbarToggle"
    type="button"
    aria-label="展开工具栏"
    aria-expanded="false"
    aria-controls="examToolbarActions"
    data-tooltip="展开工具栏"
  >
    <svg
      aria-hidden="true"
      class="h-5 w-5"
      data-toolbar-toggle-icon="open"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
    >
      <path d="M12 5v14"></path>
      <path d="M5 12h14"></path>
    </svg>
    <svg
      aria-hidden="true"
      class="h-5 w-5"
      data-toolbar-toggle-icon="close"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
    >
      <path d="m18 6-12 12"></path>
      <path d="M6 6l12 12"></path>
    </svg>
  </button>
</div>

<dialog
  id="examPrintDialog"
  class="exam-print-dialog"
  aria-labelledby="examPrintDialogTitle"
>
  <div class="exam-print-dialog-panel">
    <h2 id="examPrintDialogTitle" class="exam-print-dialog-title">打印选项</h2>
    <p class="exam-print-dialog-desc">选择要包含在打印稿中的内容。</p>
    <label class="exam-print-dialog-option">
      <input
        id="examPrintInfo"
        type="checkbox"
        checked
      />
      <span>打印试题概要信息</span>
    </label>
    <label class="exam-print-dialog-option exam-print-dialog-option-spaced">
      <input
        id="examPrintAnswers"
        type="checkbox"
        checked
      />
      <span>打印答案</span>
    </label>
    <fieldset
      id="examPrintAnswerPlacement"
      class="exam-print-dialog-fieldset"
    >
      <legend class="exam-print-dialog-legend">答案位置</legend>
      <label class="exam-print-dialog-radio">
        <input
          type="radio"
          name="examPrintAnswerPlacement"
          value="inline"
          checked
        />
        <span>放在原题位置</span>
      </label>
      <label class="exam-print-dialog-radio">
        <input
          type="radio"
          name="examPrintAnswerPlacement"
          value="end"
        />
        <span>统一放在最后</span>
      </label>
    </fieldset>
    <div class="exam-print-dialog-actions">
      <button
        id="examPrintDialogCancel"
        class="exam-print-dialog-btn exam-print-dialog-btn-secondary"
        type="button"
      >
        取消
      </button>
      <button
        id="examPrintDialogConfirm"
        class="exam-print-dialog-btn exam-print-dialog-btn-primary"
        type="button"
      >
        打印
      </button>
    </div>
  </div>
</dialog>

<style is:global>
  #examAnswersToggle [data-exam-toggle-icon] {
    display: none;
  }
  #examAnswersToggle[data-state="hidden"] [data-exam-toggle-icon="show"] {
    display: block;
  }
  #examAnswersToggle[data-state="shown"] [data-exam-toggle-icon="hide"] {
    display: block;
  }
  #backToTop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  #backToTop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
  .exam-print-dialog {
    background: none;
    border: none;
    margin: auto;
    max-width: calc(100vw - 2rem);
    padding: 0;
    width: 24rem;
  }
  .exam-print-dialog::backdrop {
    background: rgb(15 23 42 / 45%);
    backdrop-filter: blur(2px);
  }
  .exam-print-dialog-panel {
    border: 1px solid rgb(226 232 240);
    border-radius: 12px;
    background: #fff;
    box-shadow:
      0 10px 15px -3px rgb(15 23 42 / 12%),
      0 4px 6px -4px rgb(15 23 42 / 10%);
    color: rgb(15 23 42);
    padding: 1.25rem;
  }
  .dark .exam-print-dialog-panel {
    background: rgb(15 23 42);
    border-color: rgb(30 41 59);
    color: rgb(241 245 249);
  }
  .exam-print-dialog-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
  }
  .exam-print-dialog-desc {
    color: rgb(100 116 139);
    font-size: 0.875rem;
    margin: 0.4rem 0 1rem;
  }
  .dark .exam-print-dialog-desc {
    color: rgb(148 163 184);
  }
  .exam-print-dialog-option {
    align-items: center;
    border: 1px solid rgb(226 232 240);
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    gap: 0.65rem;
    font-size: 0.95rem;
    padding: 0.75rem 0.85rem;
    user-select: none;
  }
  .exam-print-dialog-option-spaced {
    margin-top: 0.75rem;
  }
  .dark .exam-print-dialog-option {
    border-color: rgb(51 65 85);
  }
  .exam-print-dialog-option input {
    accent-color: rgb(15 23 42);
    height: 1rem;
    margin: 0;
    width: 1rem;
  }
  .dark .exam-print-dialog-option input {
    accent-color: rgb(226 232 240);
  }
  .exam-print-dialog-fieldset {
    border: 1px solid rgb(226 232 240);
    border-radius: 10px;
    display: grid;
    gap: 0.55rem;
    margin: 0.75rem 0 0;
    min-inline-size: 0;
    padding: 0.75rem 0.85rem;
  }
  .dark .exam-print-dialog-fieldset {
    border-color: rgb(51 65 85);
  }
  .exam-print-dialog-fieldset:disabled {
    opacity: 0.45;
  }
  .exam-print-dialog-legend {
    color: rgb(100 116 139);
    font-size: 0.8rem;
    padding: 0 0.2rem;
  }
  .dark .exam-print-dialog-legend {
    color: rgb(148 163 184);
  }
  .exam-print-dialog-radio {
    align-items: center;
    cursor: pointer;
    display: flex;
    gap: 0.65rem;
    font-size: 0.95rem;
    user-select: none;
  }
  .exam-print-dialog-fieldset:disabled .exam-print-dialog-radio {
    cursor: default;
  }
  .exam-print-dialog-radio input {
    accent-color: rgb(15 23 42);
    height: 1rem;
    margin: 0;
    width: 1rem;
  }
  .dark .exam-print-dialog-radio input {
    accent-color: rgb(226 232 240);
  }
  .exam-print-dialog-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: flex-end;
    margin-top: 1.15rem;
  }
  .exam-print-dialog-btn {
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 0.95rem;
  }
  .exam-print-dialog-btn-secondary {
    background: transparent;
    border-color: rgb(226 232 240);
    color: rgb(51 65 85);
  }
  .dark .exam-print-dialog-btn-secondary {
    border-color: rgb(51 65 85);
    color: rgb(203 213 225);
  }
  .exam-print-dialog-btn-secondary:hover {
    background: rgb(248 250 252);
  }
  .dark .exam-print-dialog-btn-secondary:hover {
    background: rgb(30 41 59);
  }
  .exam-print-dialog-btn-primary {
    background: rgb(15 23 42);
    color: #fff;
  }
  .dark .exam-print-dialog-btn-primary {
    background: rgb(226 232 240);
    color: rgb(15 23 42);
  }
  .exam-print-dialog-btn-primary:hover {
    opacity: 0.92;
  }
  @media print {
    @page {
      margin: 2cm 1.5cm;
    }
    #examToolbar,
    #examPrintDialog {
      display: none !important;
    }
    nav, footer {
      display: none !important;
    }
    html[data-print-info="false"] #examInfoBox,
    html[data-print-info="false"] .exam-info-box {
      display: none !important;
    }
    .exam-blank {
      background: transparent !important;
      min-width: 0 !important;
    }
    .exam-blank-placeholder {
      display: none !important;
    }
    .exam-blank[aria-pressed="true"].exam-blank,
    .exam-blank[aria-pressed="false"].exam-blank {
      background: transparent !important;
      box-shadow: 0 1px 0 0 #999 !important;
      border-radius: 0 !important;
    }
    .exam-choices-submit {
      display: none !important;
    }
    .exam-choice-option {
      border-color: transparent !important;
      box-shadow: none !important;
      padding: 0.2em 0.5em !important;
    }
    .print-footer {
      display: block !important;
      margin-top: 2em;
      padding-top: 1em;
      border-top: 1px solid #ccc;
      font-size: 0.85em;
      color: #666;
      line-height: 1.8;
    }
    .print-footer a {
      color: #444;
    }
    .print-answers-appendix {
      break-before: page;
      display: block !important;
      margin-top: 0;
      padding-top: 0;
    }
    .print-answers-appendix-title {
      border-bottom: 1.5px solid #ccc;
      font-size: 1.25em;
      font-weight: 700;
      margin: 0 0 1em;
      padding-bottom: 0.4em;
    }
    .print-answer-section {
      margin: 0 0 1.35em;
    }
    .print-answer-section-title {
      font-size: 1.08em;
      font-weight: 700;
      margin: 0 0 0.55em;
    }
    .print-answer-item {
      break-inside: avoid;
      display: grid;
      gap: 0.15em 0.75em;
      grid-template-columns: max-content minmax(0, 1fr);
      margin: 0 0 0.45em;
    }
    .print-answer-item.is-section-empty {
      grid-template-columns: 1fr;
    }
    .print-answer-label {
      font-weight: 600;
      line-height: 1.7;
    }
    .print-answer-body {
      line-height: 1.7;
      min-width: 0;
    }
    .print-answer-body > :first-child {
      margin-top: 0;
    }
    .print-answer-body > :last-child {
      margin-bottom: 0;
    }

    /* Answers inline (default) */
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-blank-answer {
      visibility: visible !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-solution {
      break-inside: avoid;
      border-radius: 12px !important;
      border: 1.5px solid #ccc !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-solution[open],
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-solution:not([open]) {
      overflow: visible !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-solution-summary {
      display: none !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-solution-content {
      display: block !important;
      padding: 1em 1.2em !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices .exam-choice-option[data-answer="true"] {
      outline: 1px solid #000 !important;
      outline-offset: -2px;
      border-radius: 8px !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices .exam-choice-option.is-correct .exam-choice-indicator,
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator {
      border-color: #000 !important;
      border-width: 2px !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices .exam-choice-option.is-correct .exam-choice-indicator::after,
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      background: #000 !important;
      content: "" !important;
      inset: 1.5px !important;
      position: absolute !important;
    }
    html[data-print-answers="true"]:not([data-print-answer-placement="end"]) .exam-choices.single .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      border-radius: 50% !important;
    }

    /* Hide inline answers: no answers, or answers collected at end */
    html[data-print-answers="false"] .exam-blank-answer,
    html[data-print-answer-placement="end"] .exam-blank-answer {
      visibility: hidden !important;
    }
    html[data-print-answers="false"] .exam-solution,
    html[data-print-answer-placement="end"] .exam-solution {
      display: none !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-correct,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-wrong,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-missed {
      background: transparent !important;
      border-color: transparent !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator,
    html[data-print-answers="false"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator {
      border-color: #9ca3af !important;
      border-width: 1.5px !important;
    }
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator::after,
    html[data-print-answers="false"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator::after,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-correct .exam-choice-indicator::after,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-wrong .exam-choice-indicator::after,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option.is-missed .exam-choice-indicator::after,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-input:checked + .exam-choice-indicator::after,
    html[data-print-answer-placement="end"] .exam-choices .exam-choice-option[data-answer="true"] .exam-choice-indicator::after {
      content: none !important;
    }
  }
</style>

<script is:inline>
  var examToolbar = document.getElementById("examToolbar");
  var examToolbarToggle = document.getElementById("examToolbarToggle");
  var examAnswersToggle = document.getElementById("examAnswersToggle");
  var backToTop = document.getElementById("backToTop");
  var examPrint = document.getElementById("examPrint");
  var setExamToolbarExpanded = function(expanded) {
    if (!(examToolbar instanceof HTMLElement)) return;
    examToolbar.dataset.expanded = expanded ? "true" : "false";
    if (examToolbarToggle instanceof HTMLButtonElement) {
      examToolbarToggle.setAttribute("aria-expanded", String(expanded));
      examToolbarToggle.setAttribute(
        "aria-label",
        expanded ? "收起工具栏" : "展开工具栏",
      );
      examToolbarToggle.dataset.tooltip = expanded ? "收起工具栏" : "展开工具栏";
    }
  };
  var toggleExamToolbarExpanded = function() {
    setExamToolbarExpanded(examToolbar?.dataset.expanded !== "true");
  };

  setExamToolbarExpanded(false);
  examToolbarToggle?.addEventListener("click", function(event) {
    event.stopPropagation();
    toggleExamToolbarExpanded();
  });
  examToolbar?.querySelectorAll("[data-toolbar-action]").forEach(function(control) {
    control.addEventListener("click", function() {
      setExamToolbarExpanded(false);
    });
  });
  document.addEventListener("click", function(event) {
    if (!(examToolbar instanceof HTMLElement) || examToolbar.dataset.expanded !== "true")
      return;
    if (examToolbar.contains(event.target))
      return;
    setExamToolbarExpanded(false);
  });
  document.addEventListener("keydown", function(event) {
    if (event.key === "Escape")
      setExamToolbarExpanded(false);
  });

  // Back to top
  var updateBackToTopVisibility = function() {
    if (!backToTop) return;
    backToTop.classList.toggle("is-visible", window.scrollY > 200);
  };
  updateBackToTopVisibility();
  window.addEventListener("scroll", updateBackToTopVisibility, { passive: true });
  backToTop?.addEventListener("click", function() {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // Print options dialog
  var examPrintDialog = document.getElementById("examPrintDialog");
  var examPrintAnswers = document.getElementById("examPrintAnswers");
  var examPrintInfo = document.getElementById("examPrintInfo");
  var examPrintAnswerPlacement = document.getElementById("examPrintAnswerPlacement");
  var examPrintDialogCancel = document.getElementById("examPrintDialogCancel");
  var examPrintDialogConfirm = document.getElementById("examPrintDialogConfirm");
  var printUrlFooter = null;
  var printAnswersAppendix = null;
  var prePrintState = null;
  var printWithAnswers = true;
  var printWithInfo = true;
  var printAnswerPlacement = "inline";

  var getSelectedAnswerPlacement = function() {
    var selected = examPrintAnswerPlacement?.querySelector(
      'input[name="examPrintAnswerPlacement"]:checked',
    );
    return selected instanceof HTMLInputElement && selected.value === "end"
      ? "end"
      : "inline";
  };

  var setAnswerPlacementInputs = function(placement) {
    examPrintAnswerPlacement?.querySelectorAll(
      'input[name="examPrintAnswerPlacement"]',
    ).forEach(function(input) {
      if (input instanceof HTMLInputElement) {
        input.checked = input.value === placement;
      }
    });
  };

  var syncPrintAnswerPlacementEnabled = function() {
    if (!(examPrintAnswerPlacement instanceof HTMLFieldSetElement)) return;
    var enabled = examPrintAnswers instanceof HTMLInputElement
      ? examPrintAnswers.checked
      : true;
    examPrintAnswerPlacement.disabled = !enabled;
  };

  var findPrecedingHeadings = function(el) {
    var root = el.closest(".exam-page-main")
      || el.closest(".wiki-content")
      || document.body;
    var headings = root.querySelectorAll("h1, h2, h3, h4, h5, h6");
    var section = "";
    var subsection = "";

    for (var i = headings.length - 1; i >= 0; i -= 1) {
      var heading = headings[i];
      // Only consider headings that appear before this element.
      if (!(heading.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING)) {
        continue;
      }
      var level = Number(heading.tagName.slice(1));
      var text = (heading.textContent || "").trim();
      if (!text) continue;
      if (level >= 3) {
        if (!subsection) subsection = text;
        continue;
      }
      section = text;
      break;
    }

    return { section: section, subsection: subsection };
  };

  var findListIndexLabel = function(el) {
    var li = el.closest("li");
    if (li && li.parentElement) {
      var listParent = li.parentElement;
      var start = Number.parseInt(listParent.getAttribute("start") || "1", 10);
      if (!Number.isFinite(start)) start = 1;
      var items = Array.prototype.filter.call(
        listParent.children,
        function(child) { return child.tagName === "LI"; },
      );
      var index = items.indexOf(li);
      if (index >= 0) return String(start + index);
    }

    // Common exam MDX: "1. 题干" closes the list, then <Choices> follows as a sibling.
    var prev = el.previousElementSibling;
    while (prev) {
      if (prev.classList?.contains("exam-blank")
        || prev.classList?.contains("exam-choices")
        || prev.classList?.contains("exam-solution")
        || /^H[1-6]$/.test(prev.tagName)) {
        break;
      }
      if (prev.tagName === "OL" || prev.tagName === "UL") {
        var listStart = Number.parseInt(prev.getAttribute("start") || "1", 10);
        if (!Number.isFinite(listStart)) listStart = 1;
        var listItems = Array.prototype.filter.call(
          prev.children,
          function(child) { return child.tagName === "LI"; },
        );
        if (listItems.length) return String(listStart + listItems.length - 1);
      }
      var prevText = (prev.textContent || "").trim();
      var numbered = prevText.match(/^(\d+)\s*[.、]/);
      if (numbered) return numbered[1];
      prev = prev.previousElementSibling;
    }
    return "";
  };

  var buildLocalAnswerLabel = function(el, fallbackIndex) {
    if (el.classList.contains("exam-choices")) {
      var choiceItem = el.querySelector(".exam-choices-item");
      var choiceText = (choiceItem?.textContent || "").trim();
      if (choiceText) return { label: choiceText, sort: null };
    }
    var headings = findPrecedingHeadings(el);
    if (headings.subsection) {
      return { label: headings.subsection, sort: null };
    }
    var listIndex = findListIndexLabel(el);
    if (listIndex) {
      return { label: listIndex + ".", sort: Number(listIndex) };
    }
    return { label: String(fallbackIndex) + ".", sort: fallbackIndex };
  };

  var buildPrintAnswerLabel = function(el, fallbackIndex) {
    var local = buildLocalAnswerLabel(el, fallbackIndex);
    var headings = findPrecedingHeadings(el);
    if (el.classList.contains("exam-choices")) {
      var choiceItem = el.querySelector(".exam-choices-item");
      var choiceText = (choiceItem?.textContent || "").trim();
      if (choiceText) return choiceText;
    }
    var parts = [];
    if (headings.section) parts.push(headings.section);
    if (local.label) parts.push(local.label);
    if (parts.length) return parts.join(" · ");
    return String(fallbackIndex);
  };

  var appendClonedChildren = function(target, source) {
    Array.prototype.forEach.call(source.childNodes, function(node) {
      target.appendChild(node.cloneNode(true));
    });
  };

  var isElementAfter = function(el, marker) {
    return !!(marker.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING);
  };

  var isElementBefore = function(el, marker) {
    return !!(marker.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_PRECEDING);
  };

  var createPrintAnswerItem = function(labelText, bodyNode, options) {
    var item = document.createElement("div");
    item.className = "print-answer-item";
    if (options && options.emptySection) item.classList.add("is-section-empty");
    if (labelText) {
      var label = document.createElement("div");
      label.className = "print-answer-label";
      label.textContent = labelText;
      item.appendChild(label);
    }
    var body;
    if (bodyNode instanceof HTMLElement) {
      body = bodyNode;
      body.className = "print-answer-body";
    } else {
      body = document.createElement("div");
      body.className = "print-answer-body";
      body.textContent = typeof bodyNode === "string" ? bodyNode : "";
    }
    item.appendChild(body);
    return item;
  };

  var buildAnswerBodyFromSource = function(source) {
    var body = document.createElement("div");
    if (source.classList.contains("exam-blank")) {
      var answer = source.querySelector(".exam-blank-answer");
      if (!(answer instanceof HTMLElement)) return null;
      if (!(answer.textContent || "").trim() && !answer.querySelector(".katex, img, svg, math")) {
        return null;
      }
      appendClonedChildren(body, answer);
      return body;
    }
    if (source.classList.contains("exam-choices")) {
      var letters = [];
      source.querySelectorAll(".exam-choice-option[data-answer='true']").forEach(function(opt) {
        var letter = opt.getAttribute("data-choice");
        if (letter) letters.push(letter);
      });
      if (!letters.length) return null;
      body.textContent = letters.join("、");
      return body;
    }
    if (source.classList.contains("exam-solution")) {
      var content = source.querySelector(".exam-solution-content");
      if (!(content instanceof HTMLElement)) return null;
      if (!(content.textContent || "").trim() && !content.querySelector(".katex, img, svg, math")) {
        return null;
      }
      appendClonedChildren(body, content);
      return body;
    }
    return null;
  };

  var collectQuestionNumbersInRange = function(root, startEl, endEl) {
    var nums = [];
    Array.prototype.forEach.call(root.querySelectorAll("ol"), function(ol) {
      if (ol.closest(".related-exams")) return;
      if (!isElementAfter(ol, startEl)) return;
      if (endEl && !isElementBefore(ol, endEl)) return;
      var start = Number.parseInt(ol.getAttribute("start") || "1", 10);
      if (!Number.isFinite(start)) start = 1;
      var items = Array.prototype.filter.call(
        ol.children,
        function(child) { return child.tagName === "LI"; },
      );
      items.forEach(function(_item, index) {
        nums.push(start + index);
      });
    });
    return Array.from(new Set(nums)).sort(function(a, b) { return a - b; });
  };

  var collectSubsectionHeadingsInRange = function(root, startEl, endEl) {
    return Array.prototype.filter.call(root.querySelectorAll("h3"), function(heading) {
      if (heading.closest(".related-exams")) return false;
      if (!isElementAfter(heading, startEl)) return false;
      if (endEl && !isElementBefore(heading, endEl)) return false;
      return !!(heading.textContent || "").trim();
    });
  };

  var createAnswerSection = function(titleText) {
    var section = document.createElement("div");
    section.className = "print-answer-section";
    var title = document.createElement("h3");
    title.className = "print-answer-section-title";
    title.textContent = titleText;
    section.appendChild(title);
    return section;
  };

  var buildPrintAnswersAppendix = function() {
    var root = document.querySelector(".wiki-content .exam-page-main")
      || document.querySelector(".wiki-content");
    if (!root) return null;

    var allSources = Array.prototype.filter.call(
      root.querySelectorAll(
        ".exam-blank[aria-pressed], .exam-choices[data-has-answer='true'], .exam-solution",
      ),
      function(el) { return !el.closest(".related-exams"); },
    );
    var sectionHeadings = Array.prototype.filter.call(
      root.querySelectorAll("h2"),
      function(el) { return !el.closest(".related-exams"); },
    );

    var appendix = document.createElement("section");
    appendix.className = "print-answers-appendix";
    appendix.setAttribute("aria-label", "答案");

    var title = document.createElement("h2");
    title.className = "print-answers-appendix-title";
    title.textContent = "答案";
    appendix.appendChild(title);

    var itemCount = 0;

    var appendSourceItem = function(target, source, useLocalLabel) {
      var body = buildAnswerBodyFromSource(source);
      if (!body) return false;
      itemCount += 1;
      var labelText = useLocalLabel
        ? buildLocalAnswerLabel(source, itemCount).label
        : buildPrintAnswerLabel(source, itemCount);
      target.appendChild(createPrintAnswerItem(labelText, body));
      return true;
    };

    if (!sectionHeadings.length) {
      allSources.forEach(function(source) {
        appendSourceItem(appendix, source, false);
      });
      return itemCount > 0 ? appendix : null;
    }

    // Answers appearing before the first h2 section.
    var prefaceSources = allSources.filter(function(source) {
      return isElementBefore(source, sectionHeadings[0]);
    });
    if (prefaceSources.length) {
      prefaceSources.forEach(function(source) {
        appendSourceItem(appendix, source, false);
      });
    }

    sectionHeadings.forEach(function(heading, index) {
      var nextHeading = sectionHeadings[index + 1] || null;
      var headingText = (heading.textContent || "").trim() || ("第 " + (index + 1) + " 题");
      var section = createAnswerSection(headingText);
      var sectionSources = allSources.filter(function(source) {
        if (!isElementAfter(source, heading)) return false;
        if (nextHeading && !isElementBefore(source, nextHeading)) return false;
        return true;
      });

      var numberedEntries = {};
      var otherEntries = [];
      sectionSources.forEach(function(source) {
        var body = buildAnswerBodyFromSource(source);
        if (!body) return;
        var local = buildLocalAnswerLabel(source, Object.keys(numberedEntries).length + otherEntries.length + 1);
        if (local.sort != null && Number.isFinite(local.sort)) {
          numberedEntries[local.sort] = {
            label: local.label,
            body: body,
          };
        } else {
          otherEntries.push({
            label: local.label,
            body: body,
          });
        }
      });

      var expectedNumbers = collectQuestionNumbersInRange(root, heading, nextHeading);
      var numberedKeys = Object.keys(numberedEntries).map(Number).sort(function(a, b) { return a - b; });
      if (!expectedNumbers.length && numberedKeys.length) {
        var maxNum = numberedKeys[numberedKeys.length - 1];
        var minNum = numberedKeys[0];
        for (var n = minNum; n <= maxNum; n += 1) expectedNumbers.push(n);
      }

      if (expectedNumbers.length) {
        expectedNumbers.forEach(function(num) {
          itemCount += 1;
          var entry = numberedEntries[num];
          if (entry) {
            section.appendChild(createPrintAnswerItem(entry.label, entry.body));
            delete numberedEntries[num];
          } else {
            section.appendChild(createPrintAnswerItem(num + ".", "暂无答案"));
          }
        });
        // Any leftover numbered answers outside detected range.
        Object.keys(numberedEntries).map(Number).sort(function(a, b) { return a - b; }).forEach(function(num) {
          itemCount += 1;
          section.appendChild(
            createPrintAnswerItem(numberedEntries[num].label, numberedEntries[num].body),
          );
        });
      } else {
        numberedKeys.forEach(function(num) {
          itemCount += 1;
          section.appendChild(
            createPrintAnswerItem(numberedEntries[num].label, numberedEntries[num].body),
          );
        });
      }

      otherEntries.forEach(function(entry) {
        itemCount += 1;
        section.appendChild(createPrintAnswerItem(entry.label, entry.body));
      });

      if (!section.querySelector(".print-answer-item")) {
        var subsections = collectSubsectionHeadingsInRange(root, heading, nextHeading);
        if (subsections.length) {
          subsections.forEach(function(subheading) {
            itemCount += 1;
            section.appendChild(
              createPrintAnswerItem(
                (subheading.textContent || "").trim(),
                "暂无答案",
              ),
            );
          });
        } else {
          itemCount += 1;
          section.appendChild(
            createPrintAnswerItem("", "暂无答案", { emptySection: true }),
          );
        }
      }

      appendix.appendChild(section);
    });

    return itemCount > 0 ? appendix : null;
  };

  var openExamPrintDialog = function() {
    if (!(examPrintDialog instanceof HTMLDialogElement)) {
      window.print();
      return;
    }
    if (examPrintAnswers instanceof HTMLInputElement) {
      examPrintAnswers.checked = printWithAnswers;
    }
    if (examPrintInfo instanceof HTMLInputElement) {
      examPrintInfo.checked = printWithInfo;
    }
    setAnswerPlacementInputs(printAnswerPlacement);
    syncPrintAnswerPlacementEnabled();
    if (!examPrintDialog.open) examPrintDialog.showModal();
  };

  var closeExamPrintDialog = function() {
    if (examPrintDialog instanceof HTMLDialogElement && examPrintDialog.open) {
      examPrintDialog.close();
    }
  };

  var startExamPrint = function(withAnswers, placement, withInfo) {
    printWithAnswers = withAnswers;
    printWithInfo = withInfo;
    printAnswerPlacement = withAnswers ? placement : "inline";
    document.documentElement.dataset.printAnswers = withAnswers ? "true" : "false";
    document.documentElement.dataset.printInfo = withInfo ? "true" : "false";
    if (withAnswers) {
      document.documentElement.dataset.printAnswerPlacement = placement;
    } else {
      delete document.documentElement.dataset.printAnswerPlacement;
    }
    closeExamPrintDialog();
    window.print();
  };

  // Print preparation (works for button flow and browser print)
  window.addEventListener("beforeprint", function() {
    var withAnswers = document.documentElement.dataset.printAnswers !== "false";
    var placement = document.documentElement.dataset.printAnswerPlacement === "end"
      ? "end"
      : "inline";
    printWithAnswers = withAnswers;
    printAnswerPlacement = withAnswers ? placement : "inline";
    // Save current state to restore after print
    prePrintState = {
      blanks: [],
      solutions: [],
      choices: [],
      withAnswers: withAnswers,
      placement: placement
    };

    if (withAnswers && placement === "end") {
      printAnswersAppendix = buildPrintAnswersAppendix();
      if (printAnswersAppendix) {
        document.querySelector(".wiki-content")?.appendChild(printAnswersAppendix);
      }
    } else if (withAnswers) {
      // Reveal all answers inline
      if (!window.__examState?.getAllShown?.()) {
        window.__examState?.toggleAll?.();
        prePrintState.wasHidden = true;
      }
      // Open all <details> solutions
      document.querySelectorAll(".exam-solution:not([open])").forEach(function(el) {
        el.setAttribute("open", "");
        prePrintState.solutions.push(el);
      });
      // Show all blanks
      document.querySelectorAll(".exam-blank[aria-pressed='false']").forEach(function(el) {
        el.setAttribute("aria-pressed", "true");
        prePrintState.blanks.push(el);
      });
      // Reveal all choice answers
      document.querySelectorAll(".exam-choices[data-has-answer='true'][data-revealed='false']").forEach(function(group) {
        group.querySelectorAll(".exam-choice-option").forEach(function(opt) {
          if (opt.getAttribute("data-answer") === "true") {
            opt.classList.add("is-correct");
            var input = opt.querySelector(".exam-choice-input");
            if (input) input.checked = true;
          }
        });
        group.setAttribute("data-revealed", "true");
        prePrintState.choices.push(group);
      });
    }

    // Add print footer
    printUrlFooter = document.createElement("div");
    printUrlFooter.className = "print-footer";
    printUrlFooter.style.display = "none";
    printUrlFooter.innerHTML =
      '本页面打印自 <a href="' + window.location.href + '">' + window.location.href + '</a><br>' +
      '来源：<a href="https://wiki.byrdocs.org">BYR Docs 维基真题</a><br>' +
      '除非另有声明，本文件内容采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a> 授权。';
    document.querySelector(".wiki-content")?.appendChild(printUrlFooter);
  });
  window.addEventListener("afterprint", function() {
    // Remove temporary print nodes
    if (printAnswersAppendix) {
      printAnswersAppendix.remove();
      printAnswersAppendix = null;
    }
    if (printUrlFooter) { printUrlFooter.remove(); printUrlFooter = null; }
    // Restore previous state
    if (!prePrintState) return;
    if (prePrintState.withAnswers && prePrintState.placement !== "end") {
      if (prePrintState.wasHidden) {
        window.__examState?.toggleAll?.();
      }
      prePrintState.solutions.forEach(function(el) { el.removeAttribute("open"); });
      prePrintState.blanks.forEach(function(el) { el.setAttribute("aria-pressed", "false"); });
      prePrintState.choices.forEach(function(group) {
        group.querySelectorAll(".exam-choice-option").forEach(function(opt) {
          opt.classList.remove("is-correct");
          var input = opt.querySelector(".exam-choice-input");
          if (input) input.checked = false;
        });
        group.setAttribute("data-revealed", "false");
      });
    }
    prePrintState = null;
  });

  examPrint?.addEventListener("click", function() {
    openExamPrintDialog();
  });
  examPrintAnswers?.addEventListener("change", syncPrintAnswerPlacementEnabled);
  examPrintDialogCancel?.addEventListener("click", function() {
    closeExamPrintDialog();
  });
  examPrintDialogConfirm?.addEventListener("click", function() {
    var withAnswers = examPrintAnswers instanceof HTMLInputElement
      ? examPrintAnswers.checked
      : true;
    var withInfo = examPrintInfo instanceof HTMLInputElement
      ? examPrintInfo.checked
      : true;
    startExamPrint(withAnswers, getSelectedAnswerPlacement(), withInfo);
  });
  examPrintDialog?.addEventListener("click", function(event) {
    if (event.target === examPrintDialog) closeExamPrintDialog();
  });
  // Ctrl/Cmd+P also opens options instead of printing immediately
  window.addEventListener("keydown", function(event) {
    if (!(event.ctrlKey || event.metaKey)) return;
    if (event.key !== "p" && event.key !== "P") return;
    if (!(examPrintDialog instanceof HTMLDialogElement)) return;
    event.preventDefault();
    openExamPrintDialog();
  });

  // Answers toggle
  var updateExamAnswersToggle = function() {
    if (!(examAnswersToggle instanceof HTMLButtonElement)) return;
    var hasRevealable = window.__examState?.hasRevealable?.() ?? false;
    var allShown = hasRevealable && (window.__examState?.getAllShown?.() ?? false);
    var label = allShown ? "隐藏全部答案" : "显示全部答案";
    var tooltip = hasRevealable ? label : "暂无可显示答案";
    examAnswersToggle.disabled = !hasRevealable;
    examAnswersToggle.dataset.state = allShown ? "shown" : "hidden";
    examAnswersToggle.dataset.tooltip = tooltip;
    examAnswersToggle.setAttribute("aria-label", label);
    examAnswersToggle.setAttribute("aria-pressed", "" + allShown);
  };
  updateExamAnswersToggle();
  window.addEventListener(
    window.__examState?.events?.change ?? "examstatechange",
    updateExamAnswersToggle,
  );
  examAnswersToggle?.addEventListener("click", function() {
    window.__examState?.toggleAll?.();
  });
  requestAnimationFrame(function() { window.__examState?.sync?.(); });
</script>
