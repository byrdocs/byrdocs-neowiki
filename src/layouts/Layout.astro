---
import Footer from "/src/components/Footer.astro";
import Header from "/src/components/Header.astro";
import "/src/styles/global.css";

const {pageTitle}=Astro.props;
const organization="BYR Docs";
const pageDescription="BYR Docs 维基真题收录北京邮电大学近年试题，是一个开放、共建、共享的维基网站。";
---

<!DOCTYPE html>
<html lang="zh">
	<head>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.44/dist/katex.min.css" />
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={pageDescription} />
		<meta name="keywords" content="北邮,北京邮电大学,考试题目,维基" />
		<meta name="author" content={organization} />
		<title>{`${pageTitle} - BYR Docs 维基真题`}</title>
	</head>
	<body>
		<div class="flex min-h-screen flex-col">
			<Header pageTitle={pageTitle} />
			<main class="mx-auto flex w-full max-w-6xl flex-1 px-4 py-6 sm:px-6 lg:px-8">
				<article class="wiki-content min-w-0 flex-1">
					<slot />
				</article>
			</main>
			<Footer />
		</div>
	</body>
</html>
